    "diandian":{"provider":"minimax","voice_id":"AIBook_diandian_edge_20260715174438","speed":0.98,"vol":1.0,"pitch":1,"emotion":"happy"},
    "narrator":{"provider":"edge","voice_id":"zh-CN-XiaoxiaoNeural"},
    "kaikai":{"provider":"edge","voice_id":"zh-CN-YunxiNeural"},
    "guanguan":{"provider":"edge","voice_id":"zh-CN-XiaoyiNeural"},
    "chorus":{"provider":"edge","voice_id":"zh-CN-YunxiNeural"}
  },
  "segments":[
    {"id":"upper_01_narrator","episode":"upper","scene":1,"role":"narrator","text":"欢迎来到开关城，一座只有“开”和“关”两种模样的神奇小城。这里藏着电脑世界最基础的魔法。"},
    {"id":"upper_02_tuantuan","episode":"upper","scene":2,"role":"tuantuan","text":"这里到处都是0和1，它们是什么意思？"},
    {"id":"upper_02_diandian","episode":"upper","scene":2,"role":"diandian","text":"它们是电脑最基础的两种状态。"},
    {"id":"upper_02_narrator","episode":"upper","scene":2,"role":"narrator","text":"简单说，0和1就像电脑在说：关，或者开。"},
    {"id":"upper_03_kaikai","episode":"upper","scene":3,"role":"kaikai","text":"我是开开，我是1，代表开！"},
    {"id":"upper_03_guanguan","episode":"upper","scene":3,"role":"guanguan","text":"我是关关，我是0，代表关！"},
    {"id":"upper_03_tuantuan","episode":"upper","scene":3,"role":"tuantuan","text":"原来0和1是一对兄弟！"},
    {"id":"upper_04_diandian","episode":"upper","scene":4,"role":"diandian","text":"1像灯亮、门开、有声音；0像灯灭、门关、没声音。"},
    {"id":"upper_04_narrator","episode":"upper","scene":4,"role":"narrator","text":"对小朋友来说，0和1就像生活里的两选一：有，或者没有；开，或者关。"},
    {"id":"upper_05_guanguan","episode":"upper","scene":5,"role":"guanguan","text":"别看我们只有两个，排起队来，就能告诉大家好多秘密！"},
    {"id":"upper_05_narrator","episode":"upper","scene":5,"role":"narrator","text":"不同的排队顺序，就是不一样的悄悄话。这就是数字魔法的第一步。"},
    {"id":"upper_06_kaikai","episode":"upper","scene":6,"role":"kaikai","text":"黑卡代表开，就是我，1！"},
    {"id":"upper_06_guanguan","episode":"upper","scene":6,"role":"guanguan","text":"白卡代表关，就是我，0！"},
    {"id":"upper_06_narrator","episode":"upper","scene":6,"role":"narrator","text":"看得见的黑白卡片，就是摸得着的0和1。把卡片排成队，就能把暗号说出来。"},
    {"id":"upper_07_diandian","episode":"upper","scene":7,"role":"diandian","text":"亮一下可以是1，灭一下可以是0。连起来，就像一句完整的话。"},
    {"id":"upper_07_narrator","episode":"upper","scene":7,"role":"narrator","text":"一串串明灭的灯光，就是一串串会飞的信息。"},
    {"id":"upper_08_diandian","episode":"upper","scene":8,"role":"diandian","text":"一位只有0或1。两位排队，就有4种可能；三位排队，就有8种可能。"},
    {"id":"upper_08_narrator","episode":"upper","scene":8,"role":"narrator","text":"位数越多，能拼出来的花样就越多。"},
    {"id":"lower_01_kaikai","episode":"lower","scene":9,"role":"kaikai","text":"快看！几张卡片排一排，就能变出不一样的意思！"},
    {"id":"lower_01_narrator","episode":"lower","scene":9,"role":"narrator","text":"每一种排列，都可以代表一样东西、一个动作，或者一个小想法。"},
    {"id":"lower_02_narrator","episode":"lower","scene":10,"role":"narrator","text":"小朋友们也能动手试一试。你拼一只小猫，我拼一棵小树，亲手摆一摆，就能摸到0和1的小魔法。"},
    {"id":"lower_03_kaikai","episode":"lower","scene":11,"role":"kaikai","text":"这是我的8位笑脸编码！不用说话，看到这排卡片，就知道是开心的意思！"},
    {"id":"lower_03_narrator","episode":"lower","scene":11,"role":"narrator","text":"原来，0和1排好队，也能表示表情和心情。"},
    {"id":"lower_04_narrator","episode":"lower","scene":12,"role":"narrator","text":"我们在手机、电脑上看到的可爱表情，背后也有一排排0和1在工作。图片、声音、动画，都能变成0和1的队伍。"},
    {"id":"lower_05_diandian","episode":"lower","scene":13,"role":"diandian","text":"电脑用0和1表示、存储、传递信息。"},
    {"id":"lower_05_narrator","episode":"lower","scene":13,"role":"narrator","text":"所以我们看到的数字内容，本质上都是无数个0和1排好队，在帮电脑工作。"},
    {"id":"lower_06_guanguan","episode":"lower","scene":14,"role":"guanguan","text":"我们开关兄弟，就是让信息飞起来的魔法师。"},
    {"id":"lower_06_narrator","episode":"lower","scene":14,"role":"narrator","text":"当0和1排成不同队伍，电脑就能看懂不同的意思。"},
    {"id":"lower_07_tuantuan","episode":"lower","scene":15,"role":"tuantuan","text":"我记住了，1代表开，0代表关。"},
    {"id":"lower_07_diandian","episode":"lower","scene":15,"role":"diandian","text":"它们排成队，就能表示更多信息。"},
    {"id":"lower_07_narrator","episode":"lower","scene":15,"role":"narrator","text":"这就是电脑世界最基础、最重要的小语言。"},
    {"id":"lower_08_kaikai","episode":"lower","scene":16,"role":"kaikai","text":"要离开啦，记得我们的口诀哦！"},
    {"id":"lower_08_chorus","episode":"lower","scene":16,"role":"chorus","text":"开开关关，信息变魔法！"},
    {"id":"lower_08_narrator","episode":"lower","scene":16,"role":"narrator","text":"下一次，我们继续看看，信息怎样穿上编码的小外套。"}
  ]
}
