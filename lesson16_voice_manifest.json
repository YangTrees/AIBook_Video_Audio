  "segments": [
    {
      "id": "upper_01_narrator",
      "episode": "upper",
      "scene": 1,
      "role": "narrator",
      "text": "今天，团团和点点来到了一个热闹的公园，发现了一位非常特别的“小老师“——鹦鹉阿学！瞧，这位羽毛五彩斑斓的新朋友正站在树枝上呢！猜猜看，它今天会教给我们什么神奇的本领？"
    },
    {
      "id": "upper_02_diandian",
      "episode": "upper",
      "scene": 2,
      "role": "diandian",
      "text": "我们要学习第16课——《背答案的鹦鹉》！一起去揭开一个关于学习的超级大秘密。"
    },
    {
      "id": "upper_02_tuantuan",
      "episode": "upper",
      "scene": 2,
      "role": "tuantuan",
      "text": "背答案？点点，难道像小鹦鹉这样把答案一字不落地背下来，不算是真正学会了吗？"
    },
    {
      "id": "upper_03_narrator",
      "episode": "upper",
      "scene": 3,
      "role": "narrator",
      "text": "鹦鹉阿学（清脆地背诵）：“一一得一、一二得二、二二得四……"
    },
    {
      "id": "upper_03_tuantuan",
      "episode": "upper",
      "scene": 3,
      "role": "tuantuan",
      "text": "哇！阿学好厉害呀！居然能把这么长的乘法口诀背得这么顺溜，简直是个天才！"
    },
    {
      "id": "upper_03_diandian",
      "episode": "upper",
      "scene": 3,
      "role": "diandian",
      "text": "可是……团团，它能流利地背出这些发音，真的代表它理解这些数字背后的意思吗？"
    },
    {
      "id": "upper_04_diandian",
      "episode": "upper",
      "scene": 4,
      "role": "diandian",
      "text": "阿学，那你能告诉我们，2+2是什么意思吗？"
    },
    {
      "id": "upper_04_tuantuan",
      "episode": "upper",
      "scene": 4,
      "role": "tuantuan",
      "text": "咦？刚才还背得那么流利，怎么一问它具体的意思，阿学就卡壳说不出话了呢？"
    },
    {
      "id": "upper_05_diandian",
      "episode": "upper",
      "scene": 5,
      "role": "diandian",
      "text": "在人工智能的世界里，这叫作“过拟合“！意思是太死板地记住了见过的答案。"
    },
    {
      "id": "upper_05_narrator",
      "episode": "upper",
      "scene": 5,
      "role": "narrator",
      "text": "小鹦鹉其实根本不明白加法的含义，它只是机械地背下了声音。过拟合就像这只小鹦鹉，只会做见过的原题，一旦题目换个样子，它就彻底懵圈了！"
    },
    {
      "id": "upper_06_diandian",
      "episode": "upper",
      "scene": 6,
      "role": "diandian",
      "text": "没错！真正的学会，不是像留声机一样去死记硬背，而是去找出题目背后的规律。只有具备了“泛化能力“，才能像人工智能和聪明的小朋友一样，轻松解决从来没见过的全新挑战！"
    },
    {
      "id": "lower_01_tuantuan",
      "episode": "lower",
      "scene": 1,
      "role": "tuantuan",
      "text": "鹦鹉阿学只能记住旧题；真正的学习是学找到规律；最终举一反三，灵活运用。"
    },
    {
      "id": "lower_01_diandian",
      "episode": "lower",
      "scene": 1,
      "role": "diandian",
      "text": "过拟合就是只会死记硬背旧数据；真正学会，是要理解规律并能举一反三！无论是人类小朋友还是AI模型，最强大的学习魔法永远是“看懂规律，灵活运用“。"
    },
    {
      "id": "lower_02_tuantuan",
      "episode": "lower",
      "scene": 2,
      "role": "tuantuan",
      "text": "如果问我背过的原题，那不算真本事；但面对这道新题目，我用算术规律就能推导出来！我是算出来的，可不是背出来的哦！"
    },
    {
      "id": "lower_03_tuantuan",
      "episode": "lower",
      "scene": 3,
      "role": "tuantuan",
      "text": "哈哈，换成新题目也难不倒我们，这种“举一反三“的本领，才是最厉害的泛化大魔法！"
    },
    {
      "id": "lower_03_diandian",
      "episode": "lower",
      "scene": 3,
      "role": "diandian",
      "text": "叮咚！全员通过！大家都没有像小鹦鹉那样去死记硬背旧答案，而是真正看懂了数量变化的规律，换了新颜色、新题目也能轻松做对！"
    },
    {
      "id": "lower_04_diandian",
      "episode": "lower",
      "scene": 4,
      "role": "diandian",
      "text": "看！在神奇的AI世界里，科学家们也是这样训练AI的。我们会用全新的“测试集“去考人工智能，只有当它不会“过拟合“、能准确答对没见过的新题时，才算通过了“泛化能力验证“，成为真正聪明的AI！"
    },
    {
      "id": "lower_05_diandian",
      "episode": "lower",
      "scene": 5,
      "role": "diandian",
      "text": "今天我们收获了三个宝贵的智慧档案：第一，背答案不等于真正理解；第二，过拟合会让我们只会做旧题、不会做新题；第三，真正的学会，是理解规律、举一反三！"
    },
    {
      "id": "lower_06_tuantuan",
      "episode": "lower",
      "scene": 6,
      "role": "tuantuan",
      "text": "我要把今天战胜过拟合的秘密，好好收藏在第16课的百宝箱里！"
    },
    {
      "id": "lower_06_diandian",
      "episode": "lower",
      "scene": 6,
      "role": "diandian",
      "text": "下一课，我们将一起去探索——“认识训练集与测试集：给AI的模拟考与期末考“！小朋友们，我们下期再见啦！"
    }
  ]
}
