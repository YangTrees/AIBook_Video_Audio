  "segments": [
    {
      "id": "upper_01_narrator",
      "episode": "upper",
      "scene": 1,
      "role": "narrator",
      "text": "今天，团团和点点来到像素城堡，要一起发现一个关于“图片里的小方块“的小秘密。"
    },
    {
      "id": "upper_02_diandian",
      "episode": "upper",
      "scene": 2,
      "role": "diandian",
      "text": "我们今天要学习第5课《小方块拼出大世界》，小朋友们，你们知道电脑里那些漂亮的图片和视频是怎么画出来的吗？"
    },
    {
      "id": "upper_03_tuantuan",
      "episode": "upper",
      "scene": 3,
      "role": "tuantuan",
      "text": "看！我用电脑画了一朵向日葵！漂亮吗？"
    },
    {
      "id": "upper_03_diandian",
      "episode": "upper",
      "scene": 3,
      "role": "diandian",
      "text": "你知道这幅向日葵电脑是怎么画出来的吗？"
    },
    {
      "id": "upper_04_tuantuan",
      "episode": "upper",
      "scene": 4,
      "role": "tuantuan",
      "text": "我来用放大镜看看！"
    },
    {
      "id": "upper_04_narrator",
      "episode": "upper",
      "scene": 4,
      "role": "narrator",
      "text": "团团发现，其实电脑中的图片都是由许多纯色小方块组成的。"
    },
    {
      "id": "upper_05_diandian",
      "episode": "upper",
      "scene": 5,
      "role": "diandian",
      "text": "看！图像都是由很多很多小方块组成的！这就是电脑绘画的方法"
    },
    {
      "id": "upper_05_tuantuan",
      "episode": "upper",
      "scene": 5,
      "role": "tuantuan",
      "text": "好多好多小方块！"
    },
    {
      "id": "upper_05_diandian_02",
      "episode": "upper",
      "scene": 5,
      "role": "diandian",
      "text": "这些纯色小方块就是——像素"
    },
    {
      "id": "upper_06_diandian",
      "episode": "upper",
      "scene": 6,
      "role": "diandian",
      "text": "我们日常看到的电脑手机中的画面，都是由纯色的像素方块组成"
    },
    {
      "id": "lower_01_tuantuan",
      "episode": "lower",
      "scene": 1,
      "role": "tuantuan",
      "text": "我想把一张向日葵图票放大变清晰该怎么办？"
    },
    {
      "id": "lower_01_diandian",
      "episode": "lower",
      "scene": 1,
      "role": "diandian",
      "text": "如果不增加像素数量，单纯放大不能让图片变清晰哦"
    },
    {
      "id": "lower_02_tuantuan",
      "episode": "lower",
      "scene": 2,
      "role": "tuantuan",
      "text": "看！同样一朵花，方块大数量少图像模糊，方块小数量多图像清晰！像素越多，分辨率越高，画面就越清楚！放大不等于变清晰哦！"
    },
    {
      "id": "lower_03_narrator",
      "episode": "lower",
      "scene": 3,
      "role": "narrator",
      "text": "今天我们学到了三个魔法：第一，图片是由小方块组成的；第二，这些小方块叫做像素；第三，像素越多分辨率越高，画面越清晰；放大不等于变清晰！"
    },
    {
      "id": "lower_04_diandian",
      "episode": "lower",
      "scene": 4,
      "role": "diandian",
      "text": "你知道吗？电脑和AI也会用像素来存储图片。每一张照片、每一个表情包——都是由很多很多小方块拼成的。就像我们用乐高拼积木一样！"
    },
    {
      "id": "lower_05_diandian",
      "episode": "lower",
      "scene": 5,
      "role": "diandian",
      "text": "今天，我们学会了像素和分辨率，能把图片显示得清清楚楚——这就是像素的魔法！"
    },
    {
      "id": "lower_06_tuantuan",
      "episode": "lower",
      "scene": 6,
      "role": "tuantuan",
      "text": "我要把今天学的像素魔法收藏起来！"
    },
    {
      "id": "lower_06_diandian",
      "episode": "lower",
      "scene": 6,
      "role": "diandian",
      "text": "下一课，我们继续去发现新的AI小秘密，RGB——红绿蓝三兄弟！"
    }
  ]
}
