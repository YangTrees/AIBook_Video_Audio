  "segments": [
    {
      "id": "upper_01_narrator",
      "episode": "upper",
      "scene": 1,
      "role": "narrator",
      "text": "小朋友们好！今天，团团和点点要去一个特别的地方——那里住着一位神奇的邮差叔叔，他会教我们一个超厉害的魔法！想不想一起去看看？"
    },
    {
      "id": "upper_02_diandian",
      "episode": "upper",
      "scene": 2,
      "role": "diandian",
      "text": "我们今天要学习第3课——《小邮差的密码信》！猜猜看，“编码“是什么意思？编码就是一个超棒的魔法——给信息换一件神秘的外套！"
    },
    {
      "id": "upper_03_narrator",
      "episode": "upper",
      "scene": 3,
      "role": "narrator",
      "text": "邮差叔叔皱着眉头叹气：“唉，我要送一封很重要的信，可是坏人要是偷看了怎么办呀？"
    },
    {
      "id": "upper_04_tuantuan",
      "episode": "upper",
      "scene": 4,
      "role": "tuantuan",
      "text": "我来试试！说不定可以给信穿一件'密码外套'！"
    },
    {
      "id": "upper_04_narrator",
      "episode": "upper",
      "scene": 4,
      "role": "narrator",
      "text": "点点也来帮忙想办法啦！"
    },
    {
      "id": "upper_05_tuantuan",
      "episode": "upper",
      "scene": 5,
      "role": "tuantuan",
      "text": "我想到啦！给信穿一件'密码外套'，变成坏人看不懂的样子！"
    },
    {
      "id": "upper_05_diandian",
      "episode": "upper",
      "scene": 5,
      "role": "diandian",
      "text": "太棒了！这就是——编码！"
    },
    {
      "id": "upper_06_diandian",
      "episode": "upper",
      "scene": 6,
      "role": "diandian",
      "text": "看！同一个东西，换一种方式写出来，就是编码！"
    },
    {
      "id": "lower_01_narrator",
      "episode": "lower",
      "scene": 1,
      "role": "narrator",
      "text": "太棒了！我们已经会给信息“穿外套“了！可是穿上外套的信，怎么才能读懂呢？答案就是——解码！把外套脱掉，就能看到原来的样子啦！"
    },
    {
      "id": "lower_02_diandian",
      "episode": "lower",
      "scene": 2,
      "role": "diandian",
      "text": "编码是穿外套，解码就是脱外套！不过要记住——穿什么外套，就要脱什么外套！编码和解码，必须用同一套规则！就像是钥匙和锁，必须要配对才行哦"
    },
    {
      "id": "lower_03_diandian",
      "episode": "lower",
      "scene": 3,
      "role": "diandian",
      "text": "你知道吗？信息世界中，电脑和AI也会用这样的编码方法处理信息。它们把所有的信息——图片、音乐、动画——都用0和1来表示。就像我们给信穿外套一样，电脑也给信息穿上了'数字外套'！"
    },
    {
      "id": "lower_04_narrator",
      "episode": "lower",
      "scene": 4,
      "role": "narrator",
      "text": "同一段信息，可以有很多种表达方式——这就是编码的神奇魔法！"
    },
    {
      "id": "lower_05_narrator",
      "episode": "lower",
      "scene": 5,
      "role": "narrator",
      "text": "同一段信息，可以有很多种表达方式——这就是编码的神奇魔法！"
    },
    {
      "id": "lower_06_narrator",
      "episode": "lower",
      "scene": 6,
      "role": "narrator",
      "text": "同一段信息，可以有很多种表达方式：你好！可以用文字表示！"
    },
    {
      "id": "lower_07_narrator",
      "episode": "lower",
      "scene": 7,
      "role": "narrator",
      "text": "你好！也可以用笑脸表示！还可以用握手表示! 同一段信息，可以有很多种表达方式——这就是编码的神奇魔法！。"
    }
  ]
}
